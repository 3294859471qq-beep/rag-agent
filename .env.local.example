# ══════════════════════════════════════════════════════════════
# 聊天模型（支持 DeepSeek / SiliconFlow / 任意 OpenAI 兼容接口）
# ══════════════════════════════════════════════════════════════
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# ══════════════════════════════════════════════════════════════
# Embedding 模型 - SiliconFlow 免费（推荐）
# 注册: https://siliconflow.cn → 控制台 → API Keys
# ══════════════════════════════════════════════════════════════
EMBED_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBED_BASE_URL=https://api.siliconflow.cn/v1
EMBED_MODEL=BAAI/bge-m3

# ══════════════════════════════════════════════════════════════
# Upstash Vector 向量数据库（用于生产/Vercel 部署）
# 注册: https://upstash.com → Vector → Create Index
# 重要：创建时选择维度 1024（bge-m3 输出维度）
# ══════════════════════════════════════════════════════════════
UPSTASH_VECTOR_REST_URL=https://xxxxxxx-vector.upstash.io
UPSTASH_VECTOR_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
